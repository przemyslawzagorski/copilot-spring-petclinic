# ============================================================
# MCP Jira & Wiki Server - Konfiguracja srodowiskowa
# ============================================================
# INSTRUKCJA: Skopiuj ten plik jako .env i uzupelnij wartosci
#   cp .env.template .env   (Linux/Mac)
#   copy .env.template .env (Windows)
# ============================================================

# --- Jira Configuration (WYMAGANE) ---
# Format URL dla Atlassian Cloud: https://TWOJA-INSTANCJA.atlassian.net/rest/api/2
JIRA_BASE_URL=

# Typ autoryzacji: "basic" (Atlassian Cloud) lub "bearer" (on-premise/PAT)
JIRA_AUTH_TYPE=

# Dla basic auth (Atlassian Cloud):
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Dla bearer auth (on-premise):
# JIRA_BEARER_TOKEN=twoj-bearer-token

# --- Jira Defaults (Opcjonalne - do tworzenia ticketow) ---
JIRA_DEFAULT_PROJECT_KEY=
JIRA_DEFAULT_ISSUE_TYPE=
JIRA_DEFAULT_LABEL=

# --- Wiki / Confluence (Opcjonalne) ---
ENABLE_WIKI_INTEGRATION=

# Format URL dla Atlassian Cloud: https://TWOJA-INSTANCJA.atlassian.net/wiki/rest/api
WIKI_BASE_URL=

# Typ autoryzacji: "basic" (Atlassian Cloud) lub "bearer" (on-premise/PAT)
WIKI_AUTH_TYPE=

# Dla basic auth (Atlassian Cloud) - te same dane co Jira:
WIKI_USER_EMAIL=
WIKI_API_TOKEN=

# Dla bearer auth (on-premise):
# WIKI_BEARER_TOKEN=twoj-bearer-token

